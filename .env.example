# =============================================================================
# Amazon Second Life AI — Environment Configuration Contract
# Copy this file to .env and fill in real values for your environment.
# .env is git-ignored. Never commit secrets.
# =============================================================================

# ---------------------------------------------------------------------------
# AI Mode
# mock   = deterministic, no network, no AWS keys needed (default / CI)
# aws    = real Bedrock + Rekognition
# hybrid = Rekognition for vision, Bedrock for reasoning, mock the rest
# ---------------------------------------------------------------------------
AI_MODE=mock

# ---------------------------------------------------------------------------
# AWS (only required when AI_MODE=aws or hybrid)
# ---------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# ---------------------------------------------------------------------------
# JWT — must be identical for user service and gateway
# ---------------------------------------------------------------------------
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ---------------------------------------------------------------------------
# Postgres — one DB per service, single container
# ---------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=slmai
POSTGRES_PASSWORD=slmai_password

DATABASE_URL_GATEWAY=postgresql+asyncpg://slmai:slmai_password@localhost:5432/slmai_gateway
DATABASE_URL_USER=postgresql+asyncpg://slmai:slmai_password@localhost:5432/slmai_user
DATABASE_URL_GRADING=postgresql+asyncpg://slmai:slmai_password@localhost:5432/slmai_grading
DATABASE_URL_LIFECYCLE=postgresql+asyncpg://slmai:slmai_password@localhost:5432/slmai_lifecycle
DATABASE_URL_PASSPORT=postgresql+asyncpg://slmai:slmai_password@localhost:5432/slmai_passport
DATABASE_URL_MATCHING=postgresql+asyncpg://slmai:slmai_password@localhost:5432/slmai_matching
DATABASE_URL_SUSTAINABILITY=postgresql+asyncpg://slmai:slmai_password@localhost:5432/slmai_sustainability

# ---------------------------------------------------------------------------
# Redis (event bus)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# MinIO (S3-compatible object storage for product images/videos)
# ---------------------------------------------------------------------------
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=slmai-media
S3_REGION=us-east-1

# ---------------------------------------------------------------------------
# Service URLs (used by Gateway to proxy to individual services)
# Inside Docker Compose, use service hostnames (e.g. http://user:8001)
# For local dev outside Docker, use localhost
# ---------------------------------------------------------------------------
USER_SERVICE_URL=http://localhost:8001
GRADING_SERVICE_URL=http://localhost:8002
LIFECYCLE_SERVICE_URL=http://localhost:8003
PASSPORT_SERVICE_URL=http://localhost:8004
MATCHING_SERVICE_URL=http://localhost:8005
SUSTAINABILITY_SERVICE_URL=http://localhost:8006

# ---------------------------------------------------------------------------
# CORS — comma-separated list of allowed origins for the Gateway
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# Frontend (Next.js — only NEXT_PUBLIC_* vars are exposed to the browser)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
