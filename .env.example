# =============================================================================
# Amazon Second Life AI — Environment Configuration Contract
# =============================================================================
#
# This file is the single source of truth for all environment variables used
# across the system. Copy this file to .env and fill in real values.
#
# .env is git-ignored. Never commit secrets.
#
# Quick Start:
#   1. Copy: cp .env.example .env
#   2. Generate a secure JWT_SECRET: openssl rand -hex 32
#   3. (Optional) Add AWS credentials if using AI_MODE=aws or hybrid
#   4. Run: docker compose up --build
#
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# AI Configuration
# ─────────────────────────────────────────────────────────────────────────────
# AI_MODE controls how AI operations are executed:
#   - mock   : Deterministic, no network, no AWS keys needed (default for dev/CI)
#   - aws    : Real AWS Bedrock + Rekognition (requires AWS credentials)
#   - hybrid : Rekognition for vision, Bedrock for reasoning, mock fallback
#
# Default: mock (works without any AWS setup)
AI_MODE=mock

# ─────────────────────────────────────────────────────────────────────────────
# AWS Credentials (only required when AI_MODE=aws or hybrid)
# ─────────────────────────────────────────────────────────────────────────────
# Required for:
#   - AI Grading Service (Rekognition image/video analysis)
#   - Lifecycle Decision Service (Bedrock reasoning)
#   - Hyperlocal Matching Service (Bedrock match rationale)
#
# How to obtain:
#   1. Create an IAM user with AmazonBedrockFullAccess and AmazonRekognitionFullAccess
#   2. Generate access keys from AWS Console → IAM → Users → Security credentials
#   3. Paste the keys below
#
# WARNING: Never commit these values. Keep .env git-ignored.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Bedrock Model ID
# Tested models:
#   - anthropic.claude-3-haiku-20240307-v1:0 (fast, cost-effective, recommended)
#   - anthropic.claude-3-sonnet-20240229-v1:0 (balanced)
#   - anthropic.claude-3-opus-20240229-v1:0 (most capable, slower)
# See: https://docs.aws.amazon.com/bedrock/latest/userguide/model-ids.html
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# ─────────────────────────────────────────────────────────────────────────────
# JWT Authentication
# ─────────────────────────────────────────────────────────────────────────────
# JWT_SECRET must be identical across User Service and API Gateway.
# Generate a secure secret: openssl rand -hex 32
#
# CRITICAL: Change this in production. Use a long, random string (64+ chars).
JWT_SECRET=change-me-in-production-use-a-long-random-string

# JWT signing algorithm (HS256 = HMAC with SHA-256, standard for symmetric keys)
JWT_ALGORITHM=HS256

# JWT expiration time in minutes (1440 = 24 hours)
JWT_EXPIRE_MINUTES=1440

# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL Database
# ─────────────────────────────────────────────────────────────────────────────
# Single Postgres 16 container hosts multiple databases (logical isolation).
# Each service has its own database (no cross-service DB access).
#
# Docker Compose defaults (for containers):
#   POSTGRES_HOST=postgres (Docker service name)
#   POSTGRES_PORT=5432
#
# Local development outside Docker:
#   POSTGRES_HOST=localhost
#   POSTGRES_PORT=5432
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=slmai
POSTGRES_PASSWORD=slmai_password

# ── Per-Service Database URLs ──────────────────────────────────────────────
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DATABASE
#
# Inside Docker Compose, use: postgres:5432
# Outside Docker (local dev), use: localhost:5432
#
# Databases (created by infra/postgres/init.sql):
#   - slmai_gateway      : Return entity, purchase records
#   - slmai_user         : User accounts, profiles, green credits
#   - slmai_grading      : AI grades, damage summaries
#   - slmai_lifecycle    : Lifecycle decisions, value estimates
#   - slmai_passport     : Digital passports, product history
#   - slmai_matching     : Match requests, listings, buyer matches
#   - slmai_sustainability : CO2/waste/value metrics

DATABASE_URL_GATEWAY=postgresql+asyncpg://slmai:slmai_password@localhost:5432/slmai_gateway
DATABASE_URL_USER=postgresql+asyncpg://slmai:slmai_password@localhost:5432/slmai_user
DATABASE_URL_GRADING=postgresql+asyncpg://slmai:slmai_password@localhost:5432/slmai_grading
DATABASE_URL_LIFECYCLE=postgresql+asyncpg://slmai:slmai_password@localhost:5432/slmai_lifecycle
DATABASE_URL_PASSPORT=postgresql+asyncpg://slmai:slmai_password@localhost:5432/slmai_passport
DATABASE_URL_MATCHING=postgresql+asyncpg://slmai:slmai_password@localhost:5432/slmai_matching
DATABASE_URL_SUSTAINABILITY=postgresql+asyncpg://slmai:slmai_password@localhost:5432/slmai_sustainability

# ─────────────────────────────────────────────────────────────────────────────
# Redis (Event Bus)
# ─────────────────────────────────────────────────────────────────────────────
# Redis Streams powers the event saga choreography.
# All events flow through: slmai:events
# Failed events (after MAX_RETRIES) land in: slmai:events:dlq
#
# Docker Compose default: redis://redis:6379/0
# Local dev outside Docker: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# ─────────────────────────────────────────────────────────────────────────────
# MinIO (S3-Compatible Object Storage)
# ─────────────────────────────────────────────────────────────────────────────
# MinIO stores product images and videos uploaded during return submission.
# Bucket: slmai-media (auto-created by minio-init service)
#
# Docker Compose defaults:
#   S3_ENDPOINT_URL=http://minio:9000
#   S3_ACCESS_KEY=minioadmin
#   S3_SECRET_KEY=minioadmin
#
# Local dev outside Docker:
#   S3_ENDPOINT_URL=http://localhost:9000
#
# MinIO console: http://localhost:9001 (username: minioadmin, password: minioadmin)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=slmai-media
S3_REGION=us-east-1

# ─────────────────────────────────────────────────────────────────────────────
# Service URLs (Inter-Service Communication)
# ─────────────────────────────────────────────────────────────────────────────
# The API Gateway proxies requests to individual services.
# Frontend talks ONLY to the Gateway (never to individual services).
#
# Docker Compose defaults (service-to-service):
#   USER_SERVICE_URL=http://user:8001
#   GRADING_SERVICE_URL=http://grading:8002
#   ... etc (use Docker service names)
#
# Local dev outside Docker:
#   USER_SERVICE_URL=http://localhost:8001
#   GRADING_SERVICE_URL=http://localhost:8002
#   ... etc
USER_SERVICE_URL=http://localhost:8001
GRADING_SERVICE_URL=http://localhost:8002
LIFECYCLE_SERVICE_URL=http://localhost:8003
PASSPORT_SERVICE_URL=http://localhost:8004
MATCHING_SERVICE_URL=http://localhost:8005
SUSTAINABILITY_SERVICE_URL=http://localhost:8006

# ─────────────────────────────────────────────────────────────────────────────
# CORS Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the API Gateway.
# The frontend must be in this list to make authenticated requests.
#
# Development: http://localhost:3000
# Production: https://your-app.vercel.app,https://second-life-ai.com
CORS_ORIGINS=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# Frontend Configuration (Next.js)
# ─────────────────────────────────────────────────────────────────────────────
# Only NEXT_PUBLIC_* variables are exposed to the browser.
# Never put secrets in NEXT_PUBLIC_* variables.
#
# NEXT_PUBLIC_API_BASE_URL: The Gateway URL the frontend calls
#   - Local dev: http://localhost:8000
#   - Production (if Gateway on cloud): https://api.second-life-ai.com
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ─────────────────────────────────────────────────────────────────────────────
# Service Ports (Reference)
# ─────────────────────────────────────────────────────────────────────────────
# These ports are exposed by docker-compose.yml. DO NOT change unless you also
# update docker-compose.yml, Dockerfiles, and all service URLs above.
#
# 3000  → Web Frontend (Next.js)
# 8000  → API Gateway / BFF
# 8001  → User Service
# 8002  → AI Grading Service
# 8003  → Lifecycle Decision Service
# 8004  → Product Passport Service
# 8005  → Hyperlocal Matching Service
# 8006  → Sustainability Service
# 5432  → PostgreSQL
# 6379  → Redis
# 9000  → MinIO API
# 9001  → MinIO Console

# ─────────────────────────────────────────────────────────────────────────────
# Debugging & Observability
# ─────────────────────────────────────────────────────────────────────────────
# Gateway debug endpoints (enabled in dev, disable in production):
#   GET  /debug/events      — last N events from slmai:events
#   GET  /debug/events/dlq  — last N events from dead-letter queue
#   GET  /debug/events/stats — event counts per type
#   POST /debug/events/trigger — inject synthetic event for testing
#
# Scripts:
#   python scripts/events_tail.py tail        — stream events in real-time
#   python scripts/events_tail.py dump --dlq  — dump DLQ contents
#   python scripts/smoke_test.py              — E2E smoke test

# ─────────────────────────────────────────────────────────────────────────────
# Production Hardening Checklist
# ─────────────────────────────────────────────────────────────────────────────
# Before deploying to production:
#
# [ ] Generate a secure JWT_SECRET (64+ random characters)
# [ ] Set AI_MODE=aws or hybrid and configure AWS credentials
# [ ] Update CORS_ORIGINS to your production domain(s)
# [ ] Update NEXT_PUBLIC_API_BASE_URL to your production Gateway URL
# [ ] Disable /debug/* endpoints in Gateway (remove routes or add auth)
# [ ] Use managed PostgreSQL (AWS RDS, Azure PostgreSQL, etc.)
# [ ] Use managed Redis (AWS ElastiCache, Redis Cloud, etc.)
# [ ] Use real S3 instead of MinIO (update S3_ENDPOINT_URL)
# [ ] Enable HTTPS/TLS on all endpoints
# [ ] Set up monitoring (CloudWatch, Datadog, etc.)
# [ ] Configure log aggregation (CloudWatch Logs, ELK, etc.)
# [ ] Review and rotate all secrets regularly
# [ ] Enable database backups and test recovery
# [ ] Set up alerts for DLQ depth and saga failures

# =============================================================================
# End of Configuration
# =============================================================================
